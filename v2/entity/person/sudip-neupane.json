      "other_details": {
        "en": {
          "provenance": "translation_service",
          "value": "Strongly raising voice against anomalies and corruption, taking proactive initiatives in education and health, continuously engaged in social service, commitment to work for the country's change as long as there is a drop of blood in my body, including management of drinking water, electricity, and women's empowerment, and will continue to work for the entire Ward 3, Changunarayan Municipality, Bhaktapur."
        },
        "ne": {
          "provenance": "imported",
          "value": "विशंगती भ्रष्टाचारको विरुद्धमा संशक्त रुपमा आवाज उठाउने शिक्षा र स्वास्थ्यमा अग्रिम पहल कदमी, समाज सेवामा निरन्तर लागिरहने, खानेपानी, बिजुली, बपोदर महिलाको व्यवस्थापन आदि इत्यादि जस्ता देश परिवर्तनको निम्ती आफ्नो शरिरमा एक थोपा रगत हुन्जेल लागि रहने प्रतिबद्धता वा सम्पूर्ण चा.न.पा. ३ भक्तपुरको निम्ती लागि रहने छु।"
        }
      },
