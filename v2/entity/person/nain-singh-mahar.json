      },
      "other_details": {
        "en": {
          "provenance": "translation_service",
          "value": "I will strongly present myself on behalf of the Nepali Congress in the House of Representatives to establish the rule of law and strengthen democracy by bringing the current uncertain politics back on track. I will work nationally for political stability, the establishment of a democratic socialist society, and economic and social change. I will strive to the best of my ability for the development of Dadeldhura. With the blessings of the highly respected leader and former Prime Minister Sher Bahadur Deuba, President of the Nepali Congress, and under his successful guardianship."
        },
        "ne": {
          "provenance": "imported",
          "value": "प्रतिनिधि सभामा नेपाली काँग्रेसको तर्फबाट शसक्त रूपमा प्रस्तुत भई विधिको शासन स्थापित गर्न तथा वर्तमान अन्योल राजनीतिलाई लयमा ल्याई लोकतन्त्रलाई मजबुत गर्नमा लागि पर्ने छु। राजनीतिक स्थिरता, लोकतन्त्र समाजवाद उन्मुख समाज निर्माण तथा आर्थिक सामाजिक परिवर्तनका लागि राष्ट्रिय रूपमा लागि पर्नेछु। डडेल्धुराको विकासका लागि आफ्नो क्षमता बल बुझले भ्याए सम्म प्रयासरत रहने छु। नेपाली काँग्रेसका सभापति परम आदरणीय नेता पूर्व प्रधानमन्त्री शेर बहादुर देउवाज्यूको आर्शिवाद र वहाँको सफल अभिभावकत्वमा"
        }
      },
