      "other_details": {
        "en": {
          "provenance": "translation_service",
          "value": "My candidacy is to elevate the overall development of Myagdi district to a new height, establish corruption-free good governance, voice the dreams of youth in parliament, and with economic and political awareness and understanding of the modern world, to consider politics as a service, not a profession, and to always stand by the people of Myagdi in their joys and sorrows."
        },
        "ne": {
          "provenance": "imported",
          "value": "समग्र म्याग्दी जिल्लाको विकासलाई नयाँ उचाइमा पुर्‍याउन, भ्रष्टाचारमुक्त सुशासन कायम गर्न, युवाहरुको सपनालाई संसदमा वुलन्द पार्न तथा आधुनिक विश्वको आर्थिक राजनैतिक चेत र सुझवुझ साथै राजनीतिलाई पेशा होइन सेवा ठान्न र सदैव म्याग्देली जनताको सुखदुःखमा साथ रहने तत्परताका साथ मेरो उम्मेदवार रहेको ।"
        }
      },
      "qualification": {
