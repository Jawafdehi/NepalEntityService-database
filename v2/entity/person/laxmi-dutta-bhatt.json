      "other_details": {
        "en": {
          "provenance": "translation_service",
          "value": "Politics is service, not business. My candidacy aims to build a peaceful society where the state cares for its citizens from birth, ensuring their basic needs. This is for visionary leadership to fulfill public aspirations, promote good governance, peace, order, and progressive development, guided by an honest, patriotic, nationalist, and Nepal-centric philosophy that embraces the country's unique identity."
        },
        "ne": {
          "provenance": "imported",
          "value": "राजनीति सेवा हो, व्यापार होइन। जनताका आकांक्षा पुरा गर्न दुरदर्शी नेतृत्व समाजको शुसासन, शान्ती, अमनचयन, अग्रगामी विकासका लागि इमान्दार देशभक्त, राष्ट्रवादी, देशको आफ्नै मौलिकपन बोकेको दर्शन नेपालवादी सुविधा राज्यका लागि जन्मदै राज्यले हेर्ने जनताको सास र गास शान्तिपुर्ण समाज निर्माणका लागि मेरो उम्मेदवारी"
        }
      },
      "qualification": {
        "en": {
          "provenance": "translation_service",
          "value": "Postgraduate"
        },
        "ne": {
