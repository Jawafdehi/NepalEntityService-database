      "other_details": {
        "en": {
          "provenance": "translation_service",
          "value": "The country's politics have become unstable. There is an economic crisis in the country. And the number of unemployed youth in my area is high. My candidacy is to solve all these problems and to make strong laws. The main goal is national development, youth self-employment, and ending discrimination."
        },
        "ne": {
          "provenance": "imported",
          "value": "देशको राजनीतिक स्थिर भएको छ। देशमा आर्थिक संकट छ। र मेरो क्षेत्रमा बेरोजगारी युवाहरुको संख्या बढी छ। यिनी सबैको समस्या हल गर्नका निम्ति र बलियो कानून बनाउन मेरो उम्मेद्वारी रहेको छ। देश विकास र युवा स्वरोजगार विभेद अन्त्य नै प्रमुख लक्ष्य रहेको छ।"
        }
      },
