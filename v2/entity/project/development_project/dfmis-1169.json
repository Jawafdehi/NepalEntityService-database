  "description": {
    "en": {
      "provenance": "imported",
      "value": "# of District Development Committees with an annual multi-sectoral, gender-sensitive ECD plan (incorporating stimulation, education, health, HIV and AIDS, nutrition, protection and WASH interventions tapping local resources – linking with CFLG)\r\n\r\n \r\n\r\n% of girls and boys with ECD experience enrolled in Grade 1 in 15 priority districts\r\n\r\n \r\n\r\n% of ECD centres in priority districts applying the six learning corners (library/book, story, mathematics, drama, creative science and building blocks) as prescribed in DOE’s ECD minimum standards in 15 priority districts"
    },
