  "description": {
    "en": {
      "provenance": "imported",
      "value": "The Indigenous Nationalities Commission works to protect and promote the cultural, social, and economic rights of indigenous nationalities in Nepal. It conducts research, monitors government policies, and recommends measures to preserve indigenous identity and promote inclusive development."
    },
    "ne": {
      "provenance": "imported",
      "value": "आदिवासी जनजाति आयोगले नेपालका आदिवासी समुदायहरूको सांस्कृतिक, सामाजिक र आर्थिक अधिकारको संरक्षण र प्रवर्द्धनका लागि काम गर्दछ। यसले अनुसन्धान, नीति अनुगमन र समावेशी विकासका लागि सिफारिस गर्दछ।"
    }
  },
