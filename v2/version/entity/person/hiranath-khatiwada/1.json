        "other_details": {
          "en": {
            "provenance": "translation_service",
            "value": "I pledge to play my role as a legislator in favor of the policies and programs of a socialist system with unique Nepali characteristics, further strengthening the federal democratic republican system, and to serve as a public servant for social justice, good governance, and prosperity for the people of Nuwakot District's Constituency No. 2."
          },
          "ne": {
            "provenance": "imported",
            "value": "संघीय लोकतान्त्रिक गणतन्त्रात्मक व्यवस्थालाई थप मजबुद गराउदै नेपाली मौलिक बिशेषता सहितको समाजवादी व्यवस्थाको नीति तथा कार्यक्रमको पक्षमा विधायकको रूपमा भ‍ूमिका निर्वाह गरी समग्र नुवाकोट जिल्लाको 2 नं. निर्वाचन क्षेत्रका जनताको सामाजिक न्याय, सुशासन तथा समृद्धीको लागि आफ्नो भूमिका जनताको सेवकको रूपमा लाग्ने संकल्प गर्दछु ।"
          }
        },
