        "other_details": {
          "en": {
            "provenance": "translation_service",
            "value": "Dedicated life to social service, continuously working against corruption by not taking bribes and not allowing others to take them. Committed to ending corruption in the coming days, accelerating development work in society, promoting culture and traditions, and creating employment opportunities within the country, while continuing to engage in social service."
          },
          "ne": {
            "provenance": "imported",
            "value": "जनताको पक्षमा घुस नखाई, खान पनि नदिने गरी भ्रष्टचार विरुद्धमा निरन्तर जिवनलाई समर्पित गर्दै समाज सेवा गरेको । आगामी दिनहरुमा भ्रष्टचार अन्त्य गर्ने, समाजमा विकास निर्माणको कार्यलाई तिब्रता दिने संस्कृति संस्कारको बृद्धि गर्नुका साथै स्वादेशमा नै रोजगारी सृजना गर्ने कार्यका लागि पर्ने प्रतिबद्धता जाहेर गर्दै समाज सेवामा लागि रहने"
          }
        },
