        "other_details": {
          "en": {
            "provenance": "translation_service",
            "value": "Politics for me is not a pursuit of position or power; it is a personal belief and responsibility. I believe that only correct political belief can build a bright future for society and the country. My representation in the House of Representatives is not just for changing power, but a commitment to transform the people's standard of living through fundamental policy changes."
          },
          "ne": {
            "provenance": "imported",
            "value": "राजनीति मेरो लागि पद वा सत्ताको साधना होइन यो व्यातिगत आस्था र जिम्मेवारी हो। सहि राजनिति आस्थाले मात्र समाज र देशको उज्जवल भविष्य निर्माण गर्ने भन्न विश्वास राख्दछु।मेरो प्रतिनिधि सभा साझेदारी सत्ता परिवर्तनको लागि मात्र होइन नीतिगत रुपमा आमुल परिवर्तन मार्फत जनताको जिवन स्तर रुपान्तरणको संकल्प हो।"
          }
        },
