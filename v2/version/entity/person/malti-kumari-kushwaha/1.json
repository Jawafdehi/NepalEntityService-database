        "other_details": {
          "en": {
            "provenance": "translation_service",
            "value": "Has been working closely with the community for years on local education, health, agricultural irrigation, roads, drinking water, and employment issues. My priority is the development of Madhesh, women's safety and purification, and programs to connect youth towards employment/entrepreneurship. If elected, I pledge to adopt a transparent, accountable, and service-oriented style as a public representative."
          },
          "ne": {
            "provenance": "imported",
            "value": "स्थानिय शिक्षा, स्वास्थ्य, कृषि सिचाई सडक खानेपानी तथा रोजगारी विषयमा वर्षो देखि समुदाय सँग नजिकबाट काम गर्दै आएको, मधेशको विकाश महिला सुरक्षा  शुद्धिकरण र युवाहरुलाई रोजगारी / उद्यम तर्फ जोड्ने कार्यक्रम मेरो प्राथमिकता हो । निर्वाचनमा निर्वाचित भए जनप्रतिनिधिका रुपमा पारदर्शी, जवाफदेही र सेवा कन्द्रित शैली आपनाउने प्रतिबद्धता व्यक्त गर्दछु ।"
          }
        },
