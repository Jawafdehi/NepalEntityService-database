    "description": {
      "en": {
        "provenance": "imported",
        "value": "The National Inclusion Commission promotes social inclusion and equal representation of marginalized communities in public institutions. It monitors policies, conducts research, and recommends reforms to ensure inclusive governance in Nepal."
      },
      "ne": {
        "provenance": "imported",
        "value": "राष्ट्रिय समावेशी आयोगले सीमान्तकृत समुदायको प्रतिनिधित्व सुनिश्चित गर्दै समावेशी शासन प्रवर्द्धन गर्दछ। यसले नीति अनुगमन, अनुसन्धान र सुधारका लागि सिफारिस गर्दछ।"
      }
    },
